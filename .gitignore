# --- Secrets ---
.env
*.key
*.pem

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# --- uv (uv.lock IS committed for reproducibility) ---

# --- Notebooks ---
.ipynb_checkpoints/

# --- Caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Data lake: raw vendor pulls + cache are reproducible from the pipeline ---
data/raw/*
!data/raw/.gitkeep
data/cache/*
!data/cache/.gitkeep

# Processed parquet panels are regenerated by `raa.data.collect`; keep the
# lightweight regime label CSV (committed) so results are inspectable without an
# FMP key, but exclude the bulky price/return panels.
data/processed/*.parquet
data/processed/*.pkl
!data/processed/.gitkeep

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
